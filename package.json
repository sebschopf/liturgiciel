{
  "name": "liturgicielauri",
  "version": "0.1.0",
  "description": "Modernisation de LiturgiCiel — gestionnaire de répertoire liturgique pour Églises réformées suisses",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write src/**/*.{ts,svelte,css}",
    "format:check": "prettier --check src/**/*.{ts,svelte,css}",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:md": "markdownlint 'Documentation/**/*.md'",
    "tauri": "tauri"
  },
  "license": "GPL-3.0",
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "eslint-plugin-svelte": "^3.15.2",
    "globals": "^17.4.0",
    "open-props": "^1.7.15",
    "svelte-eslint-parser": "^1.6.0",
    "typescript-eslint": "^8.57.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@sveltejs/adapter-static": "^3.0.6",
    "@sveltejs/kit": "^2.9.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/svelte": "^5.3.1",
    "eslint": "^9.0.0",
    "markdownlint-cli": "^0.39.0",
    "prettier": "^3.0.0",
    "prettier-plugin-svelte": "^3.0.0",
    "svelte": "^5.0.0",
    "svelte-check": "^4.0.0",
    "typescript": "~5.6.2",
    "vite": "^6.0.3",
    "vitest": "^2.0.0"
  }
}
